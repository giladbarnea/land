#compdef skills skills.sh skr ske

typeset -ga _skills_subcommands=(
  'sync:Symlink SOURCE skills into each TARGET/skills directory'
  'unsync:Remove TARGET/skills symlinks that point at SOURCE skills'
)

typeset -ga _skills_sync_options=(
  '--install-githooks[Install sync logic into local git hooks and configure core.hooksPath]::hook names:_skills_git_hook_names'
  '(-h --help)'{-h,--help}'[Show help]'
)

typeset -ga _skills_target_alias_specs=(
  'claude:Alias for .claude'
  'gemini:Alias for .gemini'
  'codex:Alias for .codex'
  'pi:Alias for .pi/agent'
  'antigravity:Alias for .antigravity'
)

typeset -ga _skills_git_hook_values=(
  applypatch-msg
  pre-applypatch
  post-applypatch
  pre-commit
  pre-merge-commit
  prepare-commit-msg
  commit-msg
  post-commit
  pre-rebase
  post-checkout
  post-merge
  pre-push
)

typeset -gi _skills_runtime_helpers_loaded=0

_skills() {
  case "${words[1]}" in
    (skr) _skills_skr; return $? ;;
    (ske) _skills_ske; return $? ;;
    (skills|skills.sh) ;;
    (*) return 1 ;;
  esac

  local curcontext="$curcontext" state line
  local -i ret=1
  typeset -A opt_args

  _arguments -C \
    '1: :->subcommand' \
    '*:: :->args' && ret=0

  case $state in
    (subcommand)
      _describe -t subcommands 'skills commands' _skills_subcommands && ret=0
      ;;
    (args)
      case $line[1] in
        (sync)
          _skills:sync
          ret=$?
          ;;
        (unsync)
          _skills:unsync
          ret=$?
          ;;
        (*)
          _message 'skills command'
          ret=0
          ;;
      esac
      ;;
  esac

  return $ret
}

_skills:sync() {
  _arguments -A '-*' -s -S \
    "${_skills_sync_options[@]}" \
    '1:source parent directory:_skills_source_directory' \
    '2:target directories:_skills_target_directories' && return 0
}

_skills:unsync() {
  _arguments -A '-*' -s -S \
    '1:source parent directory:_skills_source_directory' \
    '2:target directories:_skills_target_directories' && return 0
}

_skills_source_directory() {
  _files -/
}

_skills_target_directories() {
  compset -P '*,'
  _alternative \
    'aliases:convenience target:_skills_target_aliases' \
    'directories:target directory:_skills_target_paths'
}

_skills_target_aliases() {
  _describe -t aliases 'convenience target' _skills_target_alias_specs -S ,
}

_skills_target_paths() {
  _files -/ -S ,
}

_skills_git_hook_names() {
  _values -s , 'git hook' "${_skills_git_hook_values[@]}"
}

_skills_load_runtime_helpers() {
  emulate -L zsh
  (( _skills_runtime_helpers_loaded )) && return 0

  local completion_file="${functions_source[_skills]-}" skills_file=""
  [[ -n "$completion_file" ]] || return 1

  skills_file="${completion_file:A:h:h}/skills.sh"
  [[ -f "$skills_file" ]] || return 1

  source "$skills_file" || return 1
  _skills_runtime_helpers_loaded=1
}

_skills_complete_access_options() {
  local expl
  local -a option_names option_displays

  option_names=(-g -p)
  option_displays=(
    '-g -- Use user-level skills directory'
    '-p -- Provider for skills directory'
  )

  _description options expl option
  compadd "$expl[@]" -d option_displays -a option_names
}

_skills_complete_access_providers() {
  local -a provider_specs=(
    'pi:Pi skills directory'
    'claude:Claude skills directory'
    'codex:Codex skills directory'
    'gemini:Gemini skills directory'
    'antigravity:Antigravity skills directory'
  )

  _describe -t providers 'provider' provider_specs
}

_skills_complete_access_skill_names() {
  emulate -L zsh
  local global="$1" provider="$2" base_dir="" resolution_scope="local" source_label=""
  local -a skill_names
  local expl

  [[ "$global" == "true" ]] && resolution_scope="global"

  _skills_load_runtime_helpers || return 1
  _skills_base_dir "$global" "$provider" 2>/dev/null || return 1
  base_dir="$REPLY"

  _skills_collect_resolvable_skill_names "$base_dir" || return 1
  skill_names=("${reply[@]}")
  (( ${#skill_names[@]} )) || return 1

  _skills_describe_base_dir_source "$base_dir" "$resolution_scope"
  source_label="$REPLY"

  _description -V "skills-${base_dir//[^[:alnum:]]/_}" expl "skill name from ${source_label}"
  compadd "$expl[@]" -a skill_names
}

_skills_complete_access_command() {
  emulate -L zsh
  local current_word="${words[CURRENT]-}" previous_word="${words[CURRENT-1]-}"
  local global="false" provider="" skill_name=""
  local -a completed_arguments parsed_arguments

  if [[ "$previous_word" == "-p" ]]; then
    _skills_complete_access_providers
    return $?
  fi

  if [[ "$current_word" == -* ]]; then
    _skills_complete_access_options
    return $?
  fi

  if (( CURRENT > 2 )); then
    completed_arguments=("${(@)words[2,CURRENT-1]}")
    _skills_load_runtime_helpers || return 1
    _skills_parse_access_arguments "_skills_complete_access_command" "${completed_arguments[@]}" 2>/dev/null || return 1
    parsed_arguments=("${reply[@]}")
    global="${parsed_arguments[1]}"
    provider="${parsed_arguments[2]}"
    skill_name="${parsed_arguments[3]}"
  fi

  [[ -z "$skill_name" ]] || return 1
  _skills_complete_access_skill_names "$global" "$provider"
}

_skills_complete_skill_file_paths() {
  emulate -L zsh
  local global="$1" provider="$2" skill_name="$3" base_dir="" skill_dir=""
  local -a relative_file_paths
  local expl

  _skills_load_runtime_helpers || return 1
  _skills_base_dir "$global" "$provider" 2>/dev/null || return 1
  base_dir="$REPLY"

  _skills_resolve_target "$skill_name" "$base_dir" "_skills_complete_skill_file_paths" >/dev/null 2>&1 || return 1
  skill_dir="$base_dir/$skill_name"

  relative_file_paths=("${(@f)$(builtin cd "$skill_dir" && print -rl -- **/*(.N))}")
  (( ${#relative_file_paths[@]} )) || return 1

  _description files expl 'skill file'
  compadd "$expl[@]" -a relative_file_paths
}

_skills_complete_skr_command() {
  emulate -L zsh
  local current_word="${words[CURRENT]-}" previous_word="${words[CURRENT-1]-}"
  local global="false" provider="" skill_name="" skill_file_path=""
  local -a completed_arguments parsed_arguments

  if [[ "$previous_word" == "-p" ]]; then
    _skills_complete_access_providers
    return $?
  fi

  if [[ "$current_word" == -* ]]; then
    _skills_complete_access_options
    return $?
  fi

  if (( CURRENT > 2 )); then
    completed_arguments=("${(@)words[2,CURRENT-1]}")
    _skills_load_runtime_helpers || return 1
    _skills_parse_read_arguments "_skills_complete_skr_command" "${completed_arguments[@]}" 2>/dev/null || return 1
    parsed_arguments=("${reply[@]}")
    global="${parsed_arguments[1]}"
    provider="${parsed_arguments[2]}"
    skill_name="${parsed_arguments[3]}"
    skill_file_path="${parsed_arguments[4]}"
  fi

  if [[ -z "$skill_name" ]]; then
    _skills_complete_access_skill_names "$global" "$provider"
    return $?
  fi

  [[ -z "$skill_file_path" ]] || return 1
  _skills_complete_skill_file_paths "$global" "$provider" "$skill_name"
}

_skills_skr() {
  _skills_complete_skr_command
}

_skills_ske() {
  _skills_complete_access_command
}

if [ "${funcstack[1]}" = "_skills" ]; then
  _skills "$@"
else
  compdef _skills skills skills.sh skr ske skcd skt skl
fi
