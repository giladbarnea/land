#compdef skills skills.sh skr ske

typeset -ga _skills_subcommands=(
  'sync:Symlink SOURCE skills into each TARGET/skills directory'
  'unsync:Remove TARGET/skills symlinks that point at SOURCE skills'
)

typeset -ga _skills_sync_options=(
  '--install-githooks[Install sync logic into local git hooks and configure core.hooksPath]::hook names:_skills_git_hook_names'
  '(-h --help)'{-h,--help}'[Show help]'
)

typeset -ga _skills_target_alias_specs=(
  'claude:Alias for .claude'
  'gemini:Alias for .gemini'
  'codex:Alias for .codex'
  'pi:Alias for .pi/agent'
)

typeset -ga _skills_git_hook_values=(
  applypatch-msg
  pre-applypatch
  post-applypatch
  pre-commit
  pre-merge-commit
  prepare-commit-msg
  commit-msg
  post-commit
  pre-rebase
  post-checkout
  post-merge
  pre-push
)

_skills() {
  case "${words[1]}" in
    (skr) _skills_skr; return $? ;;
    (ske) _skills_ske; return $? ;;
    (skills|skills.sh) ;;
    (*) return 1 ;;
  esac

  local curcontext="$curcontext" state line
  local -i ret=1
  typeset -A opt_args

  _arguments -C \
    '1: :->subcommand' \
    '*:: :->args' && ret=0

  case $state in
    (subcommand)
      _describe -t subcommands 'skills commands' _skills_subcommands && ret=0
      ;;
    (args)
      case $line[1] in
        (sync)
          _skills:sync
          ret=$?
          ;;
        (unsync)
          _skills:unsync
          ret=$?
          ;;
        (*)
          _message 'skills command'
          ret=0
          ;;
      esac
      ;;
  esac

  return $ret
}

_skills:sync() {
  _arguments -A '-*' -s -S \
    "${_skills_sync_options[@]}" \
    '1:source parent directory:_skills_source_directory' \
    '2:target directories:_skills_target_directories' && return 0
}

_skills:unsync() {
  _arguments -A '-*' -s -S \
    '1:source parent directory:_skills_source_directory' \
    '2:target directories:_skills_target_directories' && return 0
}

_skills_source_directory() {
  _files -/
}

_skills_target_directories() {
  compset -P '*,'
  _alternative \
    'aliases:convenience target:_skills_target_aliases' \
    'directories:target directory:_skills_target_paths'
}

_skills_target_aliases() {
  _describe -t aliases 'convenience target' _skills_target_alias_specs -S ,
}

_skills_target_paths() {
  _files -/ -S ,
}

_skills_git_hook_names() {
  _values -s , 'git hook' "${_skills_git_hook_values[@]}"
}

_skills_resolve_base_dir() {
  emulate -L zsh
  local global="false" provider="" prefix="."

  [[ -n "${opt_args[-g]}" ]] && global="true" && prefix="$HOME"
  provider="${opt_args[-p]-}"

  case "$provider" in
    pi)
      if [[ "$global" == "true" ]]; then
        REPLY="$HOME/.pi/agent/skills"
      else
        REPLY=".pi/skills"
      fi
      ;;
    claude)  REPLY="$prefix/.claude/skills" ;;
    codex)   REPLY="$prefix/.codex/skills" ;;
    gemini)  REPLY="$prefix/.gemini/skills" ;;
    "")      REPLY="$prefix/.agents/skills" ;;
  esac
}

_skills_skill_names() {
  emulate -L zsh
  local -a skill_dirs
  local base_dir

  _skills_resolve_base_dir
  base_dir="$REPLY"

  skill_dirs=("$base_dir"/*(N/:t))
  (( ${#skill_dirs[@]} )) || return 1
  _describe -t skills 'skill name' skill_dirs
}

_skills_skr() {
  local curcontext="$curcontext" state line
  local -i ret=1
  typeset -A opt_args

  _arguments -A '-*' -C \
    '-g[Use user-level skills directory]' \
    '-p[Provider for skills directory]:provider:(pi claude codex gemini)' \
    '::skill:_skills_skill_names' \
    '*:: :->rest' && ret=0

  case $state in
    (rest)
      _arguments -A '-*' -C \
        '-g[Use user-level skills directory]' \
        '-p[Provider for skills directory]:provider:(pi claude codex gemini)' && ret=0
      ;;
  esac

  return ret
}

_skills_ske() {
  local curcontext="$curcontext" state line
  local -i ret=1
  typeset -A opt_args

  _arguments -A '-*' -C \
    '-g[Use user-level skills directory]' \
    '-p[Provider for skills directory]:provider:(pi claude codex gemini)' \
    '::skill:_skills_skill_names' \
    '*:: :->rest' && ret=0

  case $state in
    (rest)
      _arguments -A '-*' -C \
        '-g[Use user-level skills directory]' \
        '-p[Provider for skills directory]:provider:(pi claude codex gemini)' && ret=0
      ;;
  esac

  return ret
}

if [ "${funcstack[1]}" = "_skills" ]; then
  _skills "$@"
else
  compdef _skills skills skills.sh skr ske
fi
