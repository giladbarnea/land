#compdef agy

_agy() {
  local curcontext="$curcontext" state line
  local -i ret=1
  typeset -A opt_args

  local -a root_options=(
    '(-c --continue)'{-c,--continue}'[Continue the most recent conversation]'
    '--conversation=[Resume a previous conversation by ID]:ID:_default'
    '--dangerously-skip-permissions[Auto-approve all tool permission requests without prompting]'
    '(-i --prompt-interactive)'{-i,--prompt-interactive}'=[Run an initial prompt interactively and continue the session]:PROMPT:_default'
    '--log-file=[Override CLI log file path]:FILE:_files'
    '--model=[Model for the current CLI session]:MODEL:_default'
    '(-p --print --prompt)'{-p,--print}'=[Run a single prompt non-interactively and print the response]:PROMPT:_default'
    '(-p --print --prompt)--prompt=[Alias for --print]:PROMPT:_default'
    '--print-timeout=[Timeout for print mode wait (default 5m0s)]:DURATION:_default'
    '--sandbox[Run in a sandbox with terminal restrictions enabled]'
    '*--add-dir=[Add a directory to the workspace (repeatable)]:DIR:_files -/'
  )

  local -a subcommands=(
    'changelog:Show changelog and release notes'
    'help:Show help for subcommands'
    'install:Configure environment paths and shell settings'
    'models:List available models'
    'plugin:Manage plugins'
    'plugins:Alias for plugin'
    'update:Update CLI'
  )

  _arguments -C \
    "${root_options[@]}" \
    '1: :->subcmd' \
    '*:: :->args' && ret=0

  case $state in
    (subcmd)
      _describe -t subcommands 'agy commands' subcommands && ret=0
      ;;
    (args)
      case $line[1] in
        (changelog|models|update)
          _arguments -C \
            '(-h --help)'{-h,--help}'[Show help]' && ret=0
          ;;
        (install)
          _agy:install
          ret=$?
          ;;
        (plugin|plugins)
          _agy:plugin
          ret=$?
          ;;
        (help)
          _arguments -C \
            ':subcommand:(changelog install models plugin plugins update)' && ret=0
          ;;
        (*)
          _default && ret=0
          ;;
      esac
      ;;
  esac

  return $ret
}

_agy:install() {
  _arguments -C \
    '(-h --help)'{-h,--help}'[Show help]' \
    '--dir=[Custom directory target to configure PATH for]:DIR:_files -/' \
    '--skip-aliases[Bypass shell profile alias purging]' \
    '--skip-path[Bypass shell profile PATH appending]' && return 0
}

_agy_plugin_names() {
  local expl
  local -a names

  names=(${(f)"$(agy plugin list 2>/dev/null)"})
  names=(${names:#No imported plugins.*})
  (( ${#names[@]} )) || return 1
  _wanted plugin-names expl 'plugin name' compadd -a names
}

_agy:plugin() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  local -a plugin_subcommands=(
    'list:List imported plugins'
    'import:Import plugins from gemini or claude'
    'install:Install a plugin (supports plugin@marketplace)'
    'uninstall:Uninstall a plugin'
    'enable:Enable a plugin'
    'disable:Disable a plugin'
    'validate:Validate a plugin at a local path'
    'link:Generate a link to a marketplace'
    'help:Show help'
  )

  _arguments -C \
    '(-h --help)'{-h,--help}'[Show help]' \
    '1: :->subcmd' \
    '*:: :->args'

  case $state in
    (subcmd)
      _describe -t subcommands 'agy plugin commands' plugin_subcommands
      ;;
    (args)
      case $line[1] in
        (list)
          _arguments -C \
            '(-h --help)'{-h,--help}'[Show help]'
          ;;
        (import)
          _arguments -C \
            '(-h --help)'{-h,--help}'[Show help]' \
            '::source:(gemini claude)'
          ;;
        (install)
          _arguments -C \
            '(-h --help)'{-h,--help}'[Show help]' \
            ':target:_default'
          ;;
        (uninstall|enable|disable)
          _arguments -C \
            '(-h --help)'{-h,--help}'[Show help]' \
            ':name:_agy_plugin_names'
          ;;
        (validate)
          _arguments -C \
            '(-h --help)'{-h,--help}'[Show help]' \
            '::path:_files -/'
          ;;
        (link)
          _arguments -C \
            '(-h --help)'{-h,--help}'[Show help]' \
            ':marketplace:_default' \
            ':target:_default'
          ;;
        (help)
          _arguments -C \
            ':subcommand:(list import install uninstall enable disable validate link)'
          ;;
      esac
      ;;
  esac
}

if [ "${funcstack[1]}" = "_agy" ]; then
  _agy "$@"
else
  compdef _agy agy
fi
